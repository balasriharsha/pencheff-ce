[
  {
    "id": "exposed-env-file",
    "info": {
      "name": "Environment File Exposed",
      "severity": "critical",
      "description": "A dotenv-style configuration file appears publicly reachable.",
      "remediation": "Remove environment files from public web roots and rotate exposed secrets.",
      "tags": ["exposure", "files", "secrets"],
      "references": ["https://owasp.org/Top10/A05_2021-Security_Misconfiguration/"],
      "classification": {
        "cwe-id": ["CWE-200", "CWE-538"],
        "cvss-score": 9.1,
        "cvss-metrics": "CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:N"
      }
    },
    "requests": [
      {
        "method": "GET",
        "path": "/.env",
        "matchers": [
          {"condition": "and"},
          {"type": "status", "status": [200]},
          {"type": "regex", "regex": ["(?m)^(APP_KEY|SECRET_KEY|DATABASE_URL|AWS_ACCESS_KEY_ID|DB_PASSWORD)="]}
        ],
        "extractors": [
          {"type": "regex", "name": "keys", "regex": ["(?m)^([A-Z0-9_]{4,})="]}
        ]
      }
    ]
  },
  {
    "id": "git-config-exposed",
    "info": {
      "name": "Git Configuration Exposed",
      "severity": "high",
      "description": "Git metadata appears publicly reachable.",
      "remediation": "Remove .git metadata from deployments or block access at the server.",
      "tags": ["exposure", "git", "files"],
      "classification": {
        "cwe-id": ["CWE-200", "CWE-548"],
        "cvss-score": 7.5,
        "cvss-metrics": "CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:N/A:N"
      }
    },
    "requests": [
      {
        "method": "GET",
        "path": "/.git/config",
        "matchers": [
          {"condition": "and"},
          {"type": "status", "status": [200]},
          {"type": "word", "words": ["[core]", "repositoryformatversion"], "condition": "and"}
        ]
      }
    ]
  },
