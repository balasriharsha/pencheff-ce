        <div className="lp-shell">
          <div className="lp-ai-sec-head">
            <div>
              <SecTag n="05." label="AI & LLM security" />
              <h2
                className="lp-h-section lp-fade-up"
                style={{ ["--lp-d" as string]: "80ms" } as React.CSSProperties}
              >
                Red team your models{" "}
                <span className="lp-italic-gilt">before attackers do.</span>
              </h2>
            </div>
            <p
              className="lp-lede lp-fade-up"
              style={{ ["--lp-d" as string]: "200ms" } as React.CSSProperties}
            >
              Pencheff covers the full OWASP LLM Top 10 (2025) with curated
              payload libraries, attacker-driven loops, and judge-backed
              scoring. Agentic testing probes tool calls, memory, planners, and
              swarm workflows. The Sentry guardrail enforces policy at runtime.
            </p>
          </div>

          <div className="lp-owasp-llm lp-fade-up">
            <div className="lp-owasp-label">OWASP LLM Top 10 · 2025</div>
            <div className="lp-owasp-grid">
              {OWASP_LLM_TOP10.map(([id, name]) => (
                <div key={id} className="lp-owasp-item">
