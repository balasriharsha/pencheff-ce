ENVIRONMENT=development
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
# CORS origins for browsers calling the API directly (static frontends call
# api.pencheff.com cross-origin). Dev: localhost; prod: the two Cloudflare sites.
ALLOWED_ORIGINS=["http://localhost:3000","https://pencheff.com","https://app.pencheff.com"]

DATABASE_URL=postgresql+asyncpg://pencheff:pencheff@localhost:5432/pencheff
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=change-me-in-prod-please-change-me-32b!
FERNET_KEY=

# ── Phase-2 feature gates ────────────────────────────────────────────────
# INTEGRATIONS_ENABLED=false
# OBSERVABILITY_INGEST_ENABLED=false

REPORT_STORAGE_DIR=/tmp/pencheff-reports
