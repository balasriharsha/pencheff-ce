{
  "manifest_version": 3,
  "name": "Pencheff Proxy",
  "description": "Capture HTTP traffic from any browser tab and stream it to a Pencheff engagement — no CA cert install required.",
  "version": "0.1.0",
  "minimum_chrome_version": "114",
  "browser_specific_settings": {
    "gecko": {
      "id": "pencheff@pencheff.io",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "webRequest",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "src/popup.html"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": false
  }
}
