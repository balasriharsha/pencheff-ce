{
  "name": "pencheff-vscode",
  "displayName": "Pencheff",
  "description": "Inline security findings in VSCode — DAST + SAST + SCA from the Pencheff agent.",
  "version": "0.1.0",
  "publisher": "pencheff",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BalaSriharsha-Ch/pencheff"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "security",
    "pentest",
    "vulnerability",
    "sca",
    "sast",
    "snyk",
    "burp"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Pencheff",
      "properties": {
        "pencheff.serverPath": {
          "type": "string",
          "default": "pencheff",
          "description": "Path to the pencheff CLI. The extension launches `<serverPath> lsp` for diagnostics.",
          "scope": "machine"
        },
        "pencheff.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace LSP messages exchanged with the Pencheff server.",
          "scope": "window"
        }
      }
    },
    "commands": [
      {
        "command": "pencheff.refresh",
        "title": "Pencheff: Refresh findings"
      },
      {
        "command": "pencheff.restart",
        "title": "Pencheff: Restart language server"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
