# docker-compose root env — loaded automatically by `docker compose`.
# Copy this file to .env and fill in your Clerk keys.
#
# The NEXT_PUBLIC_* values are baked into the Next.js bundle at build time
# (via Dockerfile ARGs), so you must rebuild after changing them:
#   docker compose up --build

NEXT_PUBLIC_API_URL=/api
# SSE bypasses the Next.js rewrite (which buffers streams); browser opens
# the EventSource against this URL directly. Set to the externally-visible
# API origin. Leave blank to fall back to NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_API_DIRECT_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ── Domain wiring (production) ───────────────────────────────────────────
# Copies are inlined into both the web and docs bundles at build time.
# Local dev leaves these as defaults and relies on NEXT_PUBLIC_*_HOST_LOCAL.
NEXT_PUBLIC_LANDING_URL=https://pencheff.com
NEXT_PUBLIC_APP_URL=https://app.pencheff.com
NEXT_PUBLIC_DOCS_URL=https://docs.pencheff.com

# ── Local-dev subdomain testing (optional) ───────────────────────────────
# Most browsers route *.localhost → 127.0.0.1 without /etc/hosts entries.
# Uncomment to exercise the subdomain middleware locally:
# NEXT_PUBLIC_APP_HOST_LOCAL=app.localhost:3000
# NEXT_PUBLIC_DOCS_HOST_LOCAL=docs.localhost:3001

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ── Plans & metering ─────────────────────────────────────────────────────
# Open-beta master switch. While true, the per-plan monthly limits below are
# NOT enforced — every org runs unmetered. Set to false to turn the caps on:
#   Free: 5 scans + 3 AI fixes / month   (Instant model)
#   Pro:  20 scans + 40 AI fixes / month (Expert model)
# Scans reset per org on the calendar-month boundary; fixes likewise.
BETA=true

# Per-plan fix-proposer model routing. Free orgs get the Instant model, paid
# orgs the Expert model. Both speak an OpenAI-compatible chat-completions API.
FIX_LLM_API_KEY=
FIX_LLM_BASE_URL=https://api.deepseek.com/v1
FIX_LLM_MODEL_FREE=deepseek-v4-flash
FIX_LLM_MODEL_PRO=deepseek-v4-pro

# Triage / grading backend (chat-completions). Operator-supplied. Leave
# blank to skip automated false-positive triage and audit-style grading;
# the heuristic grader is used as a fallback.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Pencheff scanning engine — chat-completions backend(s) that drive the
# autonomous scan stage.
#
# Feature 001 (multi-target scan pipelines) swapped the primary/fallback
# roles. The new precedence is:
#   1. AGENT_FALLBACK_LLM_*  → PRIMARY (preferred)
#   2. AGENT_LLM_*           → SECONDARY fallback
# Either set is sufficient — when only AGENT_LLM_* is configured, the
# legacy path keeps working unchanged (no flag day). Operators wanting the
# new primary set AGENT_FALLBACK_LLM_API_KEY + AGENT_FALLBACK_LLM_BASE_URL.
#
# Budget-tracking knobs (AGENT_LLM_USAGE_*) follow the ACTIVE primary —
# after the swap they apply to AGENT_FALLBACK_LLM_*'s token counts.
# Review AGENT_LLM_USAGE_THRESHOLD_PERCENT / TOKENS_PER_PERCENT for the
# new provider's pricing curve (the values below were tuned for the
# legacy primary).
AGENT_FALLBACK_LLM_API_KEY=
AGENT_FALLBACK_LLM_BASE_URL=
AGENT_FALLBACK_LLM_MODEL=
# Default 4096 (Sarvam ``starter`` tier cap for sarvam-105b). Raise to 8192
# on higher Sarvam tiers or for non-Sarvam providers without the same cap.
AGENT_FALLBACK_LLM_MAX_TOKENS=
AGENT_LLM_API_KEY=
AGENT_LLM_BASE_URL=
AGENT_LLM_MODEL=
AGENT_LLM_USAGE_MODE=tokens
AGENT_LLM_USAGE_URL=
AGENT_LLM_USAGE_SESSION_PERCENT_FIELD=
AGENT_LLM_USAGE_WEEKLY_PERCENT_FIELD=
AGENT_LLM_USAGE_THRESHOLD_PERCENT=
AGENT_LLM_USAGE_POLL_INTERVAL_SEC=
AGENT_LLM_USAGE_REQUEST_TIMEOUT=
AGENT_LLM_SESSION_WINDOW_SEC=
AGENT_LLM_WEEKLY_WINDOW_SEC=
AGENT_LLM_SESSION_TOKENS_PER_PERCENT=
AGENT_LLM_WEEKLY_TOKENS_PER_PERCENT=

# Dispatch tuning. Beta default: every scan runs the deterministic
# populator first and then hands the populated session to the autonomous
# engine. Set to `false` once Pro plans are billed. Free-plan quota is
# how many combined runs a free-plan org gets before they are downgraded
# to the autonomous-only path.
AGENT_DISPATCH_BETA_OVERRIDE=true
FREE_PLAN_OPTION_3_QUOTA=10

# Heavy Celery worker lifecycle.
# true  = current behavior: keep the toolchain worker running.
# false = API starts the worker only for queued work and stops it
#         after scans and scan-adjacent tasks drain.
WORKER_ALWAYS_ON=true
WORKER_IDLE_GRACE_SECONDS=30
DOCKER_SOCKET_PATH=/var/run/docker.sock
WORKER_COMPOSE_PROJECT=pencheff
WORKER_COMPOSE_SERVICE=worker

# ── Parallel multi-agent scan swarm ─────────────────────────────────────
# When SWARM_ENABLED=true (default), every LLM-driven scan phase runs
# through a 9-agent parallel pipeline:
#   Phase 1: ReconAgent (maps the surface)
#   Phase 2: 7 breakers in parallel (Injection, ClientSide, Auth, Authz,
#            API, Infra, Cloud — each with its own isolated pencheff
#            session seeded from a frozen ReconSnapshot)
#   Phase 3: ChainAgent (walks multi-step exploits over merged findings)
# On recon failure or all-breakers-failed, the orchestrator falls back
# to the legacy single-agent loop in agent_runner.run_agent.
# Reuses AGENT_LLM_* above; no new credentials needed.
# Set SWARM_ENABLED=false to instantly revert every scan to the legacy
# single-agent path — safe killswitch for incident response.
SWARM_ENABLED=true

# Per-phase turn budgets — each agent's tool-use loop is capped here.
# Quick stays roughly at today's single-agent budget; standard ~2× cost;
# deep is generous but bounded.
# Worst-case turn totals across the full 9-agent pipeline:
#   quick    = 8  + 6×7  + 8  =  58 turns
#   standard = 12 + 10×7 + 12 =  94 turns
#   deep     = 18 + 16×7 + 20 = 150 turns
SWARM_TURNS_RECON_QUICK=8
SWARM_TURNS_RECON_STANDARD=12
SWARM_TURNS_RECON_DEEP=18
SWARM_TURNS_BREAKER_QUICK=6
SWARM_TURNS_BREAKER_STANDARD=10
SWARM_TURNS_BREAKER_DEEP=16
SWARM_TURNS_CHAIN_QUICK=8
SWARM_TURNS_CHAIN_STANDARD=12
SWARM_TURNS_CHAIN_DEEP=20

# Per-breaker whole-run retry on transient LLM errors (timeouts, 5xx,
# 429 — after the in-loop retry budget of 3 attempts is exhausted).
# 1 = at most one retry of the entire breaker run before it is recorded
# as failed. Breakers run in parallel under asyncio.gather; one failure
# never cancels the others (Spec §6).
SWARM_BREAKER_RETRY_ATTEMPTS=1
SWARM_BREAKER_RETRY_BACKOFF_SEC=2

# ── GitHub App (repo scanning / Snyk-style PR auto-fix) ─────────────────
# Create a GitHub App at https://github.com/settings/apps/new with:
#   Permissions:
#     Repository: Contents (read+write), Metadata (read), Pull requests
#       (read+write), Dependabot alerts (read), Security events (read),
#       Actions (read).
#   Subscribe to events: push, installation, installation_repositories,
#       dependabot_alert.
#   Callback URL:  <API_BASE>/repos/callback
#   Webhook URL:   <API_BASE>/webhooks/github
# Then paste the numeric App ID, URL slug, private key, and webhook secret:
GITHUB_APP_ID=
GITHUB_APP_SLUG=pencheff
GITHUB_APP_WEBHOOK_SECRET=
# The PEM may contain newlines; use \n escapes on a single line, or wrap
# in quotes with real newlines. The service normalises both forms.
GITHUB_APP_PRIVATE_KEY=

# ── Observability (OpenTelemetry → native Postgres) ─────────────────────
# End-to-end tracing/logging/metrics across FastAPI + Celery + the MCP
# plugin + every external tool subprocess (nmap/sqlmap/etc.) + LLM agent
# turns. Stored in day-partitioned ``otel_*`` tables; retention enforced
# by an hourly Celery beat that DROPs partitions older than the day
# horizon below.
#
# Off by default: every value below is a knob, not a runtime requirement.
# Vanilla deployments pay zero overhead until ``ENABLED=true``.
PENCHEFF_OBSERVABILITY_ENABLED=false
PENCHEFF_OBSERVABILITY_SAMPLE_RATIO=1.0
PENCHEFF_OBSERVABILITY_RETENTION_DAYS=7
PENCHEFF_AUDIT_RETENTION_DAYS=7
PENCHEFF_OBSERVABILITY_SERVICE_NAME=pencheff-api
# Plugin-only: when set + a valid EngagementIngestToken is present in
# ``PENCHEFF_OBSERVABILITY_OTLP_TOKEN``, the plugin ships traces to the
# API's /v1/traces endpoint. Otherwise traces are JSONL-written under
# ``~/.pencheff/logs/`` (always-on file exporter, 7-day local prune).
PENCHEFF_OBSERVABILITY_OTLP_URL=
PENCHEFF_OBSERVABILITY_OTLP_TOKEN=
PENCHEFF_OBSERVABILITY_LOCAL_DIR=
